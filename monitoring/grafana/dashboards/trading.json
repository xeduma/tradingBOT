{
  "__inputs": [{ "name": "DS_PROMETHEUS", "type": "datasource", "pluginId": "prometheus" }],
  "title": "APEX Trading Bot",
  "uid": "apex-trading",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "PnL Jour (USD)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0 },
            { "color": "green", "value": 100 }
          ]},
          "mappings": []
        }
      },
      "targets": [{ "expr": "apex_pnl_usd", "legendFormat": "PnL", "datasource": "Prometheus" }]
    },
    {
      "id": 2, "type": "stat", "title": "Positions Ouvertes",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 7 },
            { "color": "red", "value": 10 }
          ]}
        }
      },
      "targets": [{ "expr": "apex_open_positions", "legendFormat": "Positions", "datasource": "Prometheus" }]
    },
    {
      "id": 3, "type": "stat", "title": "Latence Ordres (ms)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms", "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 30 },
            { "color": "red", "value": 50 }
          ]}
        }
      },
      "targets": [{ "expr": "rate(apex_order_latency_ms_sum[5m]) / rate(apex_order_latency_ms_count[5m])", "legendFormat": "Latence moy.", "datasource": "Prometheus" }]
    },
    {
      "id": 4, "type": "stat", "title": "Total Ordres",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [{ "expr": "sum(apex_orders_total)", "legendFormat": "Ordres", "datasource": "Prometheus" }]
    },
    {
      "id": 5, "type": "stat", "title": "Erreurs",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      },
      "targets": [{ "expr": "sum(apex_errors_total)", "legendFormat": "Erreurs", "datasource": "Prometheus" }]
    },
    {
      "id": 6, "type": "stat", "title": "Capital USD",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [{ "expr": "apex_capital_usd", "legendFormat": "Capital", "datasource": "Prometheus" }]
    },
    {
      "id": 7, "type": "timeseries", "title": "PnL en temps réel",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 0 }
          ]},
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "scheme", "spanNulls": true }
        }
      },
      "targets": [{ "expr": "apex_pnl_usd", "legendFormat": "PnL USD", "datasource": "Prometheus" }]
    },
    {
      "id": 8, "type": "timeseries", "title": "Positions ouvertes",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "spanNulls": true, "drawStyle": "line", "stacking": { "mode": "none" } }
        }
      },
      "targets": [{ "expr": "apex_open_positions", "legendFormat": "Positions", "datasource": "Prometheus" }]
    },
    {
      "id": 9, "type": "timeseries", "title": "Latence des ordres (ms)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "ms", "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 30 },
            { "color": "red", "value": 50 }
          ]},
          "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(apex_order_latency_ms_bucket[5m]))", "legendFormat": "p50", "datasource": "Prometheus" },
        { "expr": "histogram_quantile(0.95, rate(apex_order_latency_ms_bucket[5m]))", "legendFormat": "p95", "datasource": "Prometheus" },
        { "expr": "histogram_quantile(0.99, rate(apex_order_latency_ms_bucket[5m]))", "legendFormat": "p99", "datasource": "Prometheus" }
      ]
    },
    {
      "id": 10, "type": "timeseries", "title": "Ordres BUY vs SELL",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "BUY" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "SELL" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "targets": [
        { "expr": "rate(apex_orders_total{side=\"buy\"}[5m]) * 300", "legendFormat": "BUY", "datasource": "Prometheus" },
        { "expr": "rate(apex_orders_total{side=\"sell\"}[5m]) * 300", "legendFormat": "SELL", "datasource": "Prometheus" }
      ]
    },
    {
      "id": 11, "type": "timeseries", "title": "Durée cycle de trading (s)",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 6 },
      "options": { "tooltip": { "mode": "single" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s", "decimals": 2,
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "targets": [{ "expr": "apex_cycle_duration_s", "legendFormat": "Durée cycle", "datasource": "Prometheus" }]
    },
    {
      "id": 12, "type": "gauge", "title": "Utilisation positions (%)",
      "gridPos": { "x": 12, "y": 20, "w": 6, "h": 6 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 0, "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 90 }
          ]}
        }
      },
      "targets": [{ "expr": "apex_open_positions / 10 * 100", "legendFormat": "Utilisation", "datasource": "Prometheus" }]
    },
    {
      "id": 13, "type": "gauge", "title": "Santé système",
      "gridPos": { "x": 18, "y": 20, "w": 6, "h": 6 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0, "min": 0, "max": 50,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 20 },
            { "color": "red", "value": 35 }
          ]}
        }
      },
      "targets": [{ "expr": "rate(apex_order_latency_ms_sum[5m]) / rate(apex_order_latency_ms_count[5m])", "legendFormat": "Latence moy.", "datasource": "Prometheus" }]
    }
  ]
}
